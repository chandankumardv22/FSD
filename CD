#include <stdio.h>
#include <ctype.h>
#include <string.h>

int isKeyword(char str[]) {
    char *kw[] = {"int","float","if","else","while","return","char"};
    for(int i = 0; i < 7; i++)
        if(strcmp(str, kw[i]) == 0)
            return 1;
    return 0;
}

int main() {
    char input[200], token[50];
    int i = 0, j;

    printf("Enter a string:\n");
    fgets(input, sizeof(input), stdin);

    printf("\nTokens and their types:\n");

    while(input[i] != '\0') {

        if(isspace(input[i])) {
            i++;
            continue;
        }

        j = 0;

        if(isalpha(input[i]) || input[i] == '_') {
            while(isalnum(input[i]) || input[i] == '_')
                token[j++] = input[i++];

            token[j] = '\0';

            if(isKeyword(token))
                printf("%s --> Keyword\n", token);
            else
                printf("%s --> Identifier\n", token);
        }

        else if(isdigit(input[i])) {
            while(isdigit(input[i]))
                token[j++] = input[i++];

            token[j] = '\0';
            printf("%s --> Number\n", token);
        }

        else if(strchr("+-*/=<>", input[i])) {
            printf("%c --> Operator\n", input[i++]);
        }

        else if(strchr("();{},", input[i])) {
            printf("%c --> Special Symbol\n", input[i++]);
        }

        else {
            printf("%c --> Invalid Token\n", input[i++]);
        }
    }

    return 0;
}
