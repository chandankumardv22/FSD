#include <stdio.h>
#include <ctype.h>
#include <string.h>
int isKeyword(char str[]) {
    char kw[][10] = {"int","float","if","else","return"};
    for(int i = 0; i < 5; i++)
        if(strcmp(str, kw[i]) == 0)
            return 1;
    return 0;
}
int main() {
    FILE *fp;
    char ch, word[20];
    int i = 0;
    fp = fopen("input.c", "r");
    if(fp == NULL) {
        printf("File not found");
        return 0;
    }
    while((ch = fgetc(fp)) != EOF) {
        if(isalpha(ch)) {
            word[i++] = ch;
            while(isalnum(ch = fgetc(fp)))
                word[i++] = ch;
            word[i] = '\0';
            i = 0;

            if(isKeyword(word))
                printf("%s : Keyword\n", word);
            else
                printf("%s : Identifier\n", word);
        }
        else if(isdigit(ch))
            printf("%c : Constant\n", ch);
        else if(ch=='+' || ch=='-' || ch=='*' || ch=='=')
            printf("%c : Operator\n", ch);

        else if(ch==';' || ch=='(' || ch==')' || ch=='{' || ch=='}')
            printf("%c : Special Symbol\n", ch);
    }
    fclose(fp);
    return 0;
}
